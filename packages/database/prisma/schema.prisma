generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts    Account[]
  sessions    Session[]
  characters  Character[]
  campaigns   Campaign[]       @relation("DungeonMaster")
  memberships CampaignMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  inviteCode  String         @unique
  status      CampaignStatus @default(LOBBY)
  system      String         @default("D&D")
  edition     String         @default("5e")
  setting     String?
  tone        String?
  onboardingMode String      @default("beginner")
  worldName   String?
  worldSummary String?       @db.Text
  houseRules  Json?
  worldCanon  Json?
  playerCanon Json?
  rumors      Json?
  factions    Json?
  factionDirectory Json?
  storyThreads Json?
  scheduledEvents Json?
  worldRegions Json?
  loreEntries Json?
  historicalEvents Json?
  calendarState Json?
  threatClocks Json?
  unresolvedMysteries Json?
  partyTreasury Json?
  treasuryLedger Json?
  partyStash   Json?
  craftingProjects Json?
  announcements Json?
  merchants    Json?
  economyLog   Json?
  schedulePolls Json?
  campaignMessages Json?
  handouts     Json?
  groupReputation Int        @default(0)
  groupRenown Int            @default(0)
  stronghold  Json?
  sharedPlans Json?
  backups     Json?
  sessionZero Json?
  accessibilityOptions Json?

  dmId String
  dm   User   @relation("DungeonMaster", fields: [dmId], references: [id])

  members       CampaignMember[]
  npcs          NPC[]
  sessionItems  SessionItem[]
  gameSessions  GameSession[]
  locations     Location[]
  quests        Quest[]
  encounters    Encounter[]
  campaignNotes CampaignNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CampaignStatus {
  LOBBY
  ACTIVE
  ARCHIVED
}

model CampaignMember {
  id   String     @id @default(cuid())
  role MemberRole @default(PLAYER)

  userId      String
  user        User      @relation(fields: [userId], references: [id])
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  characterId String?   @unique
  character   Character? @relation(fields: [characterId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([userId, campaignId])
}

enum MemberRole {
  PLAYER
  DM
  CO_DM
  SPECTATOR
}

// ─── Character Models ────────────────────────────────────────────

model Character {
  id               String @id @default(cuid())
  name             String
  imageUrl         String?
  backstory        String? @db.Text
  level            Int    @default(1)
  experiencePoints Int    @default(0)

  // Vitality
  currentHP Int
  maxHP     Int
  tempHP    Int @default(0)

  // Combat
  armorClass      Int
  initiative      Int
  speed           Int
  proficiencyBonus Int @default(2)

  // Ability Scores
  strength     Int
  dexterity    Int
  constitution Int
  intelligence Int
  wisdom       Int
  charisma     Int

  // Proficiencies
  saveProficiencies  String[]
  skillProficiencies String[]
  skillExpertise     String[]

  // SRD References
  raceId       String
  race         Race           @relation(fields: [raceId], references: [id])
  subraceId    String?
  subrace      Subrace?       @relation(fields: [subraceId], references: [id])
  classId      String
  class        CharacterClass @relation("PrimaryCharacterClass", fields: [classId], references: [id])
  subclassId   String?
  backgroundId String
  background   Background     @relation(fields: [backgroundId], references: [id])

  // Tracking
  deathSaveSuccesses Int @default(0)
  deathSaveFailures  Int @default(0)
  exhaustionLevel    Int @default(0)
  primaryClassLevel  Int @default(1)
  hitDiceRemaining   Int
  hitDiceTotal       Int

  // Flexible class resources (ki, rages, sorcery points, etc.)
  classResources     Json?
  spellSlotsState    Json?
  pactSpellSlotsState Json?
  concentrationSpell String?
  automationMode     String @default("ASSISTED")
  rulesBookmarks     Json?
  subclassName       String?
  personalityTraits  String? @db.Text
  ideals             String? @db.Text
  bonds              String? @db.Text
  flaws              String? @db.Text
  personalGoals      String? @db.Text
  secrets            String? @db.Text
  voiceNotes         String? @db.Text
  lastSessionChanges String? @db.Text
  characterTimeline  Json?
  pendingNotifications Json?

  // Currency
  copperPieces   Int @default(0)
  silverPieces   Int @default(0)
  electrumPieces Int @default(0)
  goldPieces     Int @default(0)
  platinumPieces Int @default(0)

  // Relationships
  userId         String
  user           User               @relation(fields: [userId], references: [id])
  campaignMember CampaignMember?
  items          CharacterItem[]
  spells         CharacterSpell[]
  features       CharacterFeature[]
  conditions     CharacterCondition[]
  multiclasses   CharacterMulticlass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CharacterItem {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  imageUrl    String?
  category    String?
  rarity      String?
  value       String?
  quantity    Int     @default(1)
  weight      Float?
  isEquipped  Boolean @default(false)
  isAttuned   Boolean @default(false)
  notes       String?
  sourceSessionItemId String?
  itemHistory Json?

  characterId String
  character   Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])
}

model CharacterSpell {
  id         String  @id @default(cuid())
  isPrepared Boolean @default(false)

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spellId     String
  spell       Spell     @relation(fields: [spellId], references: [id])
  sourceClassId String?
  sourceClass   CharacterClass? @relation("SpellSourceClass", fields: [sourceClassId], references: [id])

  @@unique([characterId, spellId])
}

model CharacterMulticlass {
  id           String  @id @default(cuid())
  level        Int     @default(1)
  subclassName String?

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  classId     String
  class       CharacterClass @relation("MulticlassCharacterClass", fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, classId])
}

model CharacterFeature {
  id          String @id @default(cuid())
  name        String
  description String @db.Text
  source      String // "Race", "Class", "Background", "Feat"
  level       Int

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterCondition {
  id        String    @id @default(cuid())
  condition Condition
  appliedAt DateTime  @default(now())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, condition])
}

enum Condition {
  BLINDED
  CHARMED
  DEAFENED
  EXHAUSTION
  FRIGHTENED
  GRAPPLED
  INCAPACITATED
  INVISIBLE
  PARALYZED
  PETRIFIED
  POISONED
  PRONE
  RESTRAINED
  STUNNED
}

// ─── SRD Reference Tables ────────────────────────────────────────

model Race {
  id             String    @id @default(cuid())
  name           String    @unique
  imageUrl       String?
  speed          Int
  abilityBonuses Json      // { "strength": 2, "constitution": 1 }
  traits         Json      // [{ name, description }]
  languages      String[]
  size           String

  subraces   Subrace[]
  characters Character[]
}

model Subrace {
  id             String @id @default(cuid())
  name           String
  abilityBonuses Json
  traits         Json

  raceId     String
  race       Race        @relation(fields: [raceId], references: [id])
  characters Character[]

  @@unique([raceId, name])
}

model CharacterClass {
  id              String @id @default(cuid())
  name            String @unique
  imageUrl        String?
  hitDie          Int
  primaryAbility  String
  savingThrows    String[]
  skillChoices    String[]
  numSkillChoices Int
  proficiencies   Json   // { armor: [], weapons: [], tools: [] }
  startingEquipment Json

  levels             ClassLevel[]
  primaryCharacters  Character[]           @relation("PrimaryCharacterClass")
  multiclassEntries  CharacterMulticlass[] @relation("MulticlassCharacterClass")
  spellSourceSpells  CharacterSpell[]      @relation("SpellSourceClass")
}

model ClassLevel {
  id        String @id @default(cuid())
  level     Int
  features  Json   // [{ name, description }]
  spellSlots Json? // { "1": 2, "2": 1 }
  resources  Json? // { kiPoints: 5, rages: 3 }

  classId String
  class   CharacterClass @relation(fields: [classId], references: [id])

  @@unique([classId, level])
}

model Background {
  id                 String   @id @default(cuid())
  name               String   @unique
  imageUrl           String?
  skillProficiencies String[]
  toolProficiencies  String[]
  languages          Int      @default(0)
  equipment          Json
  feature            Json     // { name, description }

  characters Character[]
}

model Spell {
  id            String  @id @default(cuid())
  name          String  @unique
  level         Int     // 0 = cantrip
  school        String
  castingTime   String
  range         String
  components    String
  duration      String
  concentration Boolean @default(false)
  ritual        Boolean @default(false)
  description   String  @db.Text
  higherLevels  String? @db.Text
  classes       String[]

  characterSpells CharacterSpell[]
}

model Equipment {
  id          String  @id @default(cuid())
  name        String  @unique
  imageUrl    String?
  category    String
  cost        String
  weight      Float?
  properties  Json?
  description String? @db.Text

  items CharacterItem[]
}

// ─── DM Session Tracking ─────────────────────────────────────────

model NPC {
  id           String  @id @default(cuid())
  name         String
  imageUrl     String?
  description  String? @db.Text
  statBlock    Json?
  isEnemy      Boolean @default(false)
  notes        String? @db.Text

  // Enhanced NPC fields
  race         String?
  npcClass     String?  // "class" is reserved
  alignment    String?
  personality  String?  @db.Text
  appearance   String?  @db.Text
  voice        String?  // Voice/accent notes
  faction      String?
  locationName String?  // Where they can be found
  relationship String?  // ally, enemy, neutral, patron, rival
  isAlive      Boolean  @default(true)
  cr           String?  // Challenge rating

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model SessionItem {
  id          String  @id @default(cuid())
  name        String
  imageUrl    String?
  category    String?
  description String? @db.Text
  quantity    Int     @default(1)
  location    String?
  isHidden    Boolean @default(true)
  claimedById String?
  rarity      String? // "common", "uncommon", "rare", "very rare", "legendary"
  value       String? // e.g. "500 gp"

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DM Session Planning ─────────────────────────────────────────

model GameSession {
  id          String        @id @default(cuid())
  number      Int
  title       String?
  date        DateTime?
  status      SessionStatus @default(PLANNED)

  strongStart    String? @db.Text
  objectives     Json?
  scenes         Json?   // [{ title, description, type }]
  secretsAndClues Json?  // [{ secret, discovered }]
  summary        String? @db.Text
  notes          String? @db.Text
  publicRecap    String? @db.Text
  dmRecap        String? @db.Text
  pacingNotes    String? @db.Text
  attendance     Json?
  preparedChecklist Json?
  liveNotes      Json?

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SessionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

model Location {
  id          String    @id @default(cuid())
  name        String
  imageUrl    String?
  mapData     Json?
  type        String    // city, dungeon, wilderness, building, region, tavern
  description String?   @db.Text
  notes       String?   @db.Text
  parentId    String?
  parent      Location? @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[] @relation("LocationHierarchy")

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Quest {
  id          String      @id @default(cuid())
  title       String
  imageUrl    String?
  description String?     @db.Text
  status      QuestStatus @default(ACTIVE)
  priority    String      @default("normal")
  notes       String?     @db.Text
  giverNpcId  String?

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  FAILED
  ON_HOLD
}

model Encounter {
  id          String  @id @default(cuid())
  name        String
  imageUrl    String?
  description String? @db.Text
  difficulty  String? // easy, medium, hard, deadly
  monsters    Json    // [{ name, cr, count, hp, ac, notes }]
  loot        Json?   // [{ name, quantity, description }]
  liveState   Json?
  notes       String? @db.Text
  status      String  @default("prepared") // prepared, active, completed

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignNote {
  id       String  @id @default(cuid())
  title    String
  content  String  @db.Text
  category String  @default("general") // general, lore, rules, faction, plot
  isPinned Boolean @default(false)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
